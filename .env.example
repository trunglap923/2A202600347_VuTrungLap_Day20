# Required if using a real LLM provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional tracing providers
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=multi-agent-research-lab
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=multi-agent-research-lab
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional search provider
TAVILY_API_KEY=

# Runtime config
APP_ENV=local
LOG_LEVEL=INFO
MAX_ITERATIONS=6
TIMEOUT_SECONDS=60
